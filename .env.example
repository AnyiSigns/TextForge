# text-forge 环境变量示例（提交进库，作为模板）
# 复制为 .env.development / .env.production 后按需修改，真实密钥勿提交。

# 多环境标识：development | staging | production
# 开发期留空即走 dev mock（NEXT_PUBLIC_API_URL 为空串时全部请求走 /api/* 的本地 mock）。
NEXT_PUBLIC_ENV=development

# 后端基址：
#   - 开发期留空 → 走前端内置 mock（无需启动后端，Zero-后端可运行）。
#   - 对接真实后端时填其地址，例如 http://localhost:8000
NEXT_PUBLIC_API_URL=

# 监控 DSN（Sentry 兼容）：留空则降级为 localStorage 环形缓冲（仅本地调试用）。
NEXT_PUBLIC_SENTRY_DSN=

# 应用版本（用于监控 release 标记，缺省自动取 env）。
NEXT_PUBLIC_APP_VERSION=
